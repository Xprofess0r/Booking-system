# Server Configuration
PORT=3002

# MySQL Database (update config/config.json for DB credentials)

# Flight Service - URL of the Flight/Search microservice
# e.g. http://localhost:3001
FLIGHT_SERVICE_PATH=http://localhost:3001

# RabbitMQ Message Broker
# e.g. amqp://localhost or amqp://user:pass@host:5672
MESSAGE_BROKER_URL=amqp://localhost

# RabbitMQ Exchange and Binding Keys
EXCHANGE_NAME=AIRLINE_NOTIFICATION

# Binding key for the notification/reminder service queue
REMINDER_BINDING_KEY=REMINDER_BINDING_KEY

# Set to true to auto-sync DB schema on server start (dev only)
# DB_SYNC=true
